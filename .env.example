# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepInfra API Configuration
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# Google Vertex AI Configuration (for Gemini models)
# Authentication: run `gcloud auth application-default login` before starting
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_LOCATION=global

# HuggingFace Configuration (for downloading GAIA dataset)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Web Search Tool Configuration (for WEB_SEARCH operator)
# Get your key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# SQL Tool Configuration (for SQL_QUERY operator)
# Examples:
#   SQLite:     sqlite:///path/to/database.db
#   PostgreSQL: postgresql://user:password@host:5432/dbname
#   MySQL:      mysql+pymysql://user:password@host:3306/dbname
SQL_DB_URL=sqlite:///data/database.db

# Optional: Proxy Configuration
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=http://proxy:port

# Optional: Local Model Configuration
# LOCAL_MODEL_BASE_URL=http://localhost:8000
